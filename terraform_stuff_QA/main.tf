terraform {
  required_providers {
    null = {
      source  = "hashicorp/null"
      version = "~> 3.0"
    }
  }
}

resource "null_resource" "g1" {
  count = 1000
  triggers = {
    a = "${count.index}-g1a-"
    b = "${count.index}-g1b-"
    c = "${count.index}-g1c-"
    d = "${count.index}-g1d-"
    e = "${count.index}-g1e-"
    f = "${count.index}-g1f-"
    g = "${count.index}-g1g-"
    h = "${count.index}-g1h-"
  }
}
